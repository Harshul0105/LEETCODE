        int n = height.size();
        int left = 0;
        int right = n-1;
        int maxWater = 0;
        while(left < right)
        {
            int wid = right - left;
            int minHeight = min(height[left], height[right] );
            int volume = wid * minHeight;
            maxWater = max(maxWater, volume);
            if(height[left] < height[right] )
            {
                left++;
            }
            else
            {
                right--;
            }
        }
        return maxWater;
    }
