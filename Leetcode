        st = []

        mapping = {
            ')': '(',
            '}': '{',
            ']': '['
        }

        for ch in s:

            # Opening brackets
            if ch in "({[":
                st.append(ch)

            # Closing brackets
            else:

                if not st:
                    return False

                top = st.pop()

                if mapping[ch] != top:
                    return False

