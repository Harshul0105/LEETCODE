public:
    long long maximumSubarraySum(vector<int>& nums, int k) 
    {
        int n = nums.size();
	   unordered_set<int> history;
	   long long currentSum = 0;
	   long long maxSum  = 0;
	   int left= 0;
	   for(int right=0; right<n; right++)
