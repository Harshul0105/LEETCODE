#include<iostream>
using namespace std;

class Solution {
    void solve(int n, int sum){
        if(n==0){
            return;
        }
        sum=0;
        int rem= n%10;
        sum=sum+rem;
        solve(n/10, sum);
    }
  public:
    int sumOfDigits(int n) {
        int sum=0;
        solve(n, sum);
        return sum;
    }
};

Question 3: Factorial

class Solution{
    int fact(int n){
        if(n==0)
        return 1;
        
        return n*fact(n-1);
        
        }
    public:
    int factorial(int n){
        return fact(n);
    }
};
